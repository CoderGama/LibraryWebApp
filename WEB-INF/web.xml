<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee" version="3.1">

    <!-- Welcome Page -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Book Servlet (existing) -->
    <servlet>
        <servlet-name>BookServlet</servlet-name>
        <servlet-class>controller.BookServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>BookServlet</servlet-name>
        <url-pattern>/BookServlet</url-pattern>
    </servlet-mapping>

    <!-- Login Servlet (NEW) -->
    <servlet>
        <servlet-name>LoginServlet</servlet-name>
        <servlet-class>controller.LoginServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>LoginServlet</servlet-name>
        <url-pattern>/LoginServlet</url-pattern>
    </servlet-mapping>

    <!-- Issue Book Servlet (NEW) -->
    <servlet>
        <servlet-name>IssueServlet</servlet-name>
        <servlet-class>controller.IssueServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>IssueServlet</servlet-name>
        <url-pattern>/IssueServlet</url-pattern>
    </servlet-mapping>

    <!-- Return Book Servlet (NEW) -->
    <servlet>
        <servlet-name>ReturnServlet</servlet-name>
        <servlet-class>controller.ReturnServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>ReturnServlet</servlet-name>
        <url-pattern>/ReturnServlet</url-pattern>
    </servlet-mapping>

</web-app>